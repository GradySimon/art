{
  "name": "@grady/art",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A portable catalog and gallery for browser-based works",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GradySimon/art.git"
  },
  "exports": {
    ".": "./src/core/index.ts",
