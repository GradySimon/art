---
import {discoverCatalog} from "../../runtime/discover";
import type {WorkPath} from "../../core";
import WorkPlayer from "../../components/WorkPlayer.astro";
import {galleryWorkHref} from "./gallery-route";
import "./gallery.css";

interface Props {
  initialWork?: WorkPath;
  basePath?: string;
}

const catalog = await discoverCatalog();
if (catalog.length === 0) throw new Error("No works were discovered");
const requestedInitial = Astro.props.initialWork;
const basePath = Astro.props.basePath ?? "/works";
const initialIndex = requestedInitial
  ? catalog.findIndex(({fullPath}) => fullPath === requestedInitial)
  : 0;
if (initialIndex < 0) throw new Error(`Unknown initial work: ${requestedInitial}`);
const initial = catalog[initialIndex];
---

<main
  class="gallery"
  data-gallery
  data-initial-href={galleryWorkHref(initial.fullPath, basePath)}
>
  <header class="masthead">
    <h1>Works</h1>
    <div class="work-picker">
      <button data-previous aria-label="Previous work">←</button>
      <select data-work-select aria-label="Work">
        {catalog.map((work, index) => (
          <option
            value={work.fullPath}
            selected={index === initialIndex}
            data-href={galleryWorkHref(work.fullPath, basePath)}
            data-title={work.title}
            data-description={work.description}
            data-date={work.date ?? ""}
            data-workspace={work.workspaceTitle}
          >
            {String(index + 1).padStart(2, "0")} — {work.title}
          </option>
        ))}
      </select>
      <button data-next aria-label="Next work">→</button>
    </div>
  </header>

  <section class="work-shell" aria-label="Selected work">
    <WorkPlayer
      work={initial.fullPath}
      class="gallery-player"
      data-gallery-player
      label={initial.title}
    />
    <div class="work-caption">
      <span data-work-number>
        {String(initialIndex + 1).padStart(2, "0")} / {String(catalog.length).padStart(2, "0")}
      </span>
      <div class="work-description">
        <strong data-work-title>{initial.title}</strong>
        <span data-work-note>{initial.description}</span>
        <span data-work-date>{initial.date}</span>
        <span data-workspace-label>{initial.workspaceTitle}</span>
      </div>
    </div>
  </section>
</main>

<script>
  import "./gallery-client";
</script>
