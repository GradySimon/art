---
import type {WorkPath} from "../core";

interface Props {
  work: WorkPath;
  aspectRatio?: number;
  class?: string;
  label?: string;
  [attribute: string]: unknown;
}

const {
  work,
  aspectRatio,
  class: className,
  label = "Interactive work",
  ...attributes
} = Astro.props;
---

<work-player
  {...attributes}
  work={work}
  class:list={["work-player", className]}
  style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
  role="img"
  aria-label={label}
></work-player>

<script>
  import "../runtime/player-element";
</script>

<style>
  .work-player {
    display: block;
    width: 100%;
    min-height: 240px;
    overflow: hidden;
    background: #e3e1dc;
  }

  .work-player[data-state="error"] {
    padding: 1rem;
    font: 0.875rem/1.5 monospace;
    color: #8a241f;
  }
</style>
